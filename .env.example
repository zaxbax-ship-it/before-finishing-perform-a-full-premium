NEXT_PUBLIC_DATABASE_MODE=local
NEXT_PUBLIC_COMMUNITY_SUBMISSIONS_ENABLED=true
NEXT_PUBLIC_ADMIN_DASHBOARD_ENABLED=true

# Supabase/PostgreSQL. Keep local mode until the migration is applied and data is seeded.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Browser-safe Supabase client key. Required by Supabase Auth (login/session).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI and moderation stay disabled until explicitly connected.
OPENAI_API_KEY=
OPENAI_MODERATION_ENABLED=false
OPENAI_MODERATION_MODEL=gpt-4.1-mini

# Authentication (Supabase Auth).
# Auth is enforced automatically once NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY
# are set. Until then the app runs in open local mode (unchanged behavior).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Absolute site origin for OAuth / email redirect links (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=
# Set to false to run a configured Supabase project without enforcing admin auth (staging).
AUTH_ENFORCED=
# Set to false to hide the email/password option and offer Google only.
AUTH_EMAIL_PASSWORD_ENABLED=true
# Comma-separated bootstrap admins granted super_admin before the admins table is seeded.
ADMIN_EMAILS=

# Advertising stays disabled until a provider is approved and connected.
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_AD_PROVIDER=none
NEXT_PUBLIC_AD_PLACEHOLDERS=true
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=
GOOGLE_AD_MANAGER_NETWORK_CODE=

# Payments.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Email.
RESEND_API_KEY=

# Bot protection.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Analytics.
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_POSTHOG_KEY=
